NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Optional — enables LLM-driven invoice line items
ANTHROPIC_API_KEY=

# ── Lead Engine ───────────────────────────────────────────────────
# Separate Supabase project (NOT the Krileo Webapp DB).
# Service-role key is server-only.
LEAD_ENGINE_URL=
LEAD_ENGINE_SERVICE_KEY=

# Apify
APIFY_API_TOKEN=
APIFY_ACTOR_ID=

# Bearer secret for /api/cron/* endpoints
CRON_SECRET=

# Flip to "true" once Smartlead inbox warmup is >95% (~Day 10-14).
# Until then, all outreach is cold-call (30/day).
LEAD_ENGINE_EMAIL_READY=false

# Optional — Smartlead push + reply handler
SMARTLEAD_API_KEY=

# Optional — PageSpeed enrichment
PAGESPEED_API_KEY=

# Optional — Cal.com booking link embedded in cold-mail copy
CALCOM_BOOKING_URL=

# Optional — Hot-lead notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
